{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.arturskowronski/minipainter",
  "title": "minipainter",
  "description": "Local-first miniature-paint inventory and cross-brand color matching for AI agents.",
  "version": "0.7.2",
  "repository": {
    "url": "https://github.com/ArturSkowronski/minipainter",
    "source": "github"
  },
  "websiteUrl": "https://arturskowronski.github.io/minipainter/",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "minipainter",
      "version": "0.7.2",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-y"
        },
        {
          "type": "positional",
          "value": "-p"
        },
        {
          "type": "positional",
          "value": "minipainter"
        }
      ],
      "packageArguments": [
        {
          "type": "positional",
          "value": "minipainter-mcp"
        }
      ],
      "environmentVariables": [
        {
          "name": "INVENTORY_PATH",
          "description": "Path to the inventory JSON file. Defaults to ~/.minipainting/inventory.json.",
          "isRequired": false
        }
      ]
    }
  ]
}
