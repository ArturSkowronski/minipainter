# Postgres-backed inventory — used by `docker compose` and remote deploys.
# Leave DATABASE_URL unset to fall back to a local JSON inventory file (unchanged behavior).
DATABASE_URL=postgres://warpaint:warpaint@localhost:5432/warpaint

# HTTP server port
PORT=3000

# Optional bearer token protecting /mcp, /mcp/v3 and /api/*
# AUTH_TOKEN=change-me

# Optional: seed the inventory on first boot (applied only while the DB is empty)
# INVENTORY_JSON={"version":1,"owned":["citadel/abaddon-black"]}
